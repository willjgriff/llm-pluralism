{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Fetch Evaluation Responses",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "evaluation_query"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Fetch Persona Responses",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "persona_query"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Fetch All Responses",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "evaluation_query", "persona_query"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Persona Response Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "persona_response_analyse"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "All Pre-Survey Fetch + Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [ "--mode", "evaluation_query", "persona_query", "persona_response_analyse"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Fetch Survey Responses",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/fetch_survey_data.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Survey Response Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "survey_response_analyse"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
    ]
}
