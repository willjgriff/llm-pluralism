{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Evaluation Query",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "evaluation_query"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Persona Query",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "persona_query"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "All query",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "evaluation_query", "persona_query"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Persona Response Analyse",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "persona_response_analyse"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "All, pre-survey analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [ "--mode", "evaluation_query", "persona_query", "persona_response_analyse"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Fetch survey results",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/fetch_survey_data.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Survey Response Analyse",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": ["--mode", "survey_response_analyse"],
            "python": "${workspaceFolder}/.venv/bin/python"
        },
    ]
}
