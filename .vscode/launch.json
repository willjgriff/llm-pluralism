    "version": "0.2.0",
    "configurations": [
        {
            "name": "Query And Analyse",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "args": ["--mode", "both", "--copy-readme-images"]
        },
        {
            "name": "Query Models",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "args": ["--mode", "query"]
        },
        {
            "name": "Run Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/run.py",
            "console": "integratedTerminal",
            "args": ["--mode", "analyse", "--copy-readme-images"]
        }
    ]
}